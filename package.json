{
  "name": "agentic-swarm",
  "version": "2.0.0",
  "description": "Deployable swarms of specialist AI agents — organized into teams, installed with one command. Claude Code, Codex, OpenCode, Cursor & Pi.",
  "bin": {
    "agentic-swarm": "bin/cli.js"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=14"
  },
  "files": [
    "bin/",
    "agents/",
    "teams/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "python scripts/add_frontmatter.py && python scripts/build_teams.py",
    "start": "node bin/cli.js"
  },
  "keywords": [
    "ai-agents",
    "agent-swarm",
    "agentic",
    "claude-code",
    "codex",
    "opencode",
    "cursor",
    "subagents",
    "code-review",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hlsitechio/agentic-swarm.git"
  },
  "homepage": "https://github.com/hlsitechio/agentic-swarm#readme",
  "bugs": {
    "url": "https://github.com/hlsitechio/agentic-swarm/issues"
  },
  "author": "hlsitechio",
  "license": "MIT"
}
